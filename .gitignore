# =============================================================================
# VA Suite / ForensicAuth — .gitignore
# GitHub limits: 100 MB/file (normal Git), 2 GB/file (LFS).
# Pesos de modelo: baixar via scripts/download_*.py ou HuggingFace, não commitar.
# =============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# IDEs / editor local
.vscode/
.idea/
.cursor/
*.swp
*.swo
*~

# Jupyter
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# Node / React
node_modules/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

