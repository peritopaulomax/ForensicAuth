# ForensicAuth Environment Configuration

# Application
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-in-production-forensicauth-2026

# Security (required in production)
# Generate a strong SECRET_KEY, e.g.: openssl rand -hex 32
# Generate Ed25519 custody key pair via scripts/generate_custody_signing_key.py
CUSTODY_SIGNING_PRIVATE_KEY=
CUSTODY_SIGNING_PUBLIC_KEY=

# Database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/forensicauth

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Storage
UPLOAD_DIR=./uploads
RESULTS_DIR=./results
DERIVATIVES_DIR=./derivatives
PERITUS_CASES_DIR=./peritus_cases
MODELS_DIR=./models
JOB_PREVIEW_RETENTION_DAYS=0
JOB_PREVIEW_DAILY_CLEANUP=true
JOB_PREVIEW_CLEANUP_HOUR=2
HF_HUB_CACHE=./models/synthetic_image_detection/huggingface
TRANSFORMERS_OFFLINE=1

# GPU
GPU_AVAILABLE=false

# Paralelismo interno (joblib por job — não exposto na UI)
# Regra prática: nucleos ≈ (jobs Celery simultâneos) × N_JOBS + ~8 reserva (API/DB/SO)
# Ex.: worker -c 4 + JPEG_GHOSTS_N_JOBS=6 → até ~24 núcleos em Ghosts pesados
JPEG_GHOSTS_N_JOBS=6
PRNU_LOCALIZED_N_JOBS=4
# Copy-Move PCA: Numba + OpenCV + OpenBLAS (0 = auto, todos os nucleos)
COPY_MOVE_PCA_N_JOBS=0
