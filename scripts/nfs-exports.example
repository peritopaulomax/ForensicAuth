# Exemplo /etc/exports — maquina principal ForensicAuth
# Ajuste <WORKER_SUBNET> para a rede LAN dos workers (ex.: 10.0.0.0/24).
# Apos editar: sudo exportfs -ra && sudo systemctl restart nfs-kernel-server

/opt/forensicauth/uploads-dev     <WORKER_SUBNET>(rw,sync,no_subtree_check,no_root_squash)
/opt/forensicauth/results-dev     <WORKER_SUBNET>(rw,sync,no_subtree_check,no_root_squash)
/opt/forensicauth/derivatives-dev <WORKER_SUBNET>(rw,sync,no_subtree_check,no_root_squash)
/opt/forensicauth/models          <WORKER_SUBNET>(ro,sync,no_subtree_check,no_root_squash)

# Producao (docker volumes no host):
# /srv/forensicauth/uploads      <WORKER_SUBNET>(rw,sync,no_subtree_check,no_root_squash)
# /srv/forensicauth/results      <WORKER_SUBNET>(rw,sync,no_subtree_check,no_root_squash)
# /srv/forensicauth/derivatives  <WORKER_SUBNET>(rw,sync,no_subtree_check,no_root_squash)
# /srv/forensicauth/models       <WORKER_SUBNET>(ro,sync,no_subtree_check,no_root_squash)
