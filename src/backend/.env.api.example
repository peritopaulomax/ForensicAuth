# ForensicAuth — API (FastAPI). Copie para src/backend/.env ao rodar uvicorn.
# Nao usar GPU neste processo.

FORENSICAUTH_PROCESS_ROLE=api
GPU_AVAILABLE=false
ML_WARMUP_ON_STARTUP=false

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5433/forensicauth_dev
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/0

UPLOAD_DIR=../../uploads-dev
RESULTS_DIR=../../results-dev
DERIVATIVES_DIR=../../derivatives-dev
PERITUS_CASES_DIR=../../peritus_cases-dev
MODELS_DIR=../../models
JOB_PREVIEW_RETENTION_DAYS=0
JOB_PREVIEW_DAILY_CLEANUP=true
JOB_PREVIEW_CLEANUP_HOUR=2

DEBUG=true
SECRET_KEY=dev-only-not-for-production-vasuite-2026
