# ForensicAuth — Celery worker GPU. Copie e ajuste ao iniciar worker-gpu.

FORENSICAUTH_PROCESS_ROLE=worker-gpu
FORENSICAUTH_WORKER_QUEUE=gpu
GPU_AVAILABLE=true
ML_WARMUP_ON_STARTUP=true
EFFORT_WARMUP_ON_STARTUP=true
EFFORT_WARMUP_VARIANTS=genimage
SYNTHETIC_KEEP_RESIDENT=true
GPU_RESIDENT_TECHNIQUES=synthetic,effort,safe
GPU_DISTRIBUTED_LOCK=true

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5433/forensicauth_dev
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/0

UPLOAD_DIR=../../uploads-dev
RESULTS_DIR=../../results-dev
DERIVATIVES_DIR=../../derivatives-dev
PERITUS_CASES_DIR=../../peritus_cases-dev
MODELS_DIR=../../models
HF_HUB_CACHE=../../models/synthetic_image_detection/huggingface
TRANSFORMERS_OFFLINE=1

DEBUG=true
SECRET_KEY=dev-only-not-for-production-vasuite-2026
