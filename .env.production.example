# ForensicAuth — producao (docker-compose.gpu.yml)
# Copie para .env na raiz e ajuste secrets/paths antes do deploy.

# --- Imagem / reproducibilidade ---
FORENSICAUTH_IMAGE_TAG=forensicauth:prod
FORENSICAUTH_IMAGE_DIGEST=

# --- Banco e filas ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/forensicauth
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- API (servico app) ---
FORENSICAUTH_PROCESS_ROLE=api
FORENSICAUTH_WORKER_QUEUE=
GPU_AVAILABLE=false
ML_WARMUP_ON_STARTUP=false
EFFORT_WARMUP_ON_STARTUP=false
GPU_DISTRIBUTED_LOCK=true

# --- Worker CPU ---
# FORENSICAUTH_PROCESS_ROLE=worker-cpu
# FORENSICAUTH_WORKER_QUEUE=celery
# GPU_AVAILABLE=false
# ML_WARMUP_ON_STARTUP=false

# --- Worker GPU ---
# FORENSICAUTH_PROCESS_ROLE=worker-gpu
# FORENSICAUTH_WORKER_QUEUE=gpu
# GPU_AVAILABLE=true
# ML_WARMUP_ON_STARTUP=true
# EFFORT_WARMUP_ON_STARTUP=true
# EFFORT_WARMUP_VARIANTS=genimage
# SYNTHETIC_KEEP_RESIDENT=true
# GPU_RESIDENT_TECHNIQUES=synthetic,effort,safe
# GPU_LRU_TTL_SECONDS=1800
# GPU_RESERVED_FUTURE_MB=7000
# GPU_MIN_FREE_MB=1500
# CUDA_VISIBLE_DEVICES=0

# --- Storage (paths dentro do container; volumes no compose) ---
UPLOAD_DIR=/app/uploads
RESULTS_DIR=/app/results
DERIVATIVES_DIR=/app/derivatives
PERITUS_CASES_DIR=/app/peritus_cases
MODELS_DIR=/app/models

# --- Seguranca ---
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
DEBUG=false

# --- CORS (frontend em producao) ---
# CORS_ORIGINS=["https://forensicauth.example.com"]

# --- Paralelismo interno ---
JPEG_GHOSTS_N_JOBS=6
PRNU_LOCALIZED_N_JOBS=4
COPY_MOVE_PCA_N_JOBS=0
